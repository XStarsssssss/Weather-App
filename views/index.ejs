<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css"> 
    <title>Weather Result</title>
</head>
<body class="body">
    <div class="container text-center mt-5 main-container">

        <div class="search-container">
      <div class="title-con">
         <h1 class="Title">Weather App</h1>
      </div>

      <form method="post" action="/">
        <div class="row justify-content-center mt-4">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="input-group mb-3">
                    <input type="text" class="form-control input-box" name="city_search" placeholder="City Name" required>
                    <button class="btn btn-outline-light btn-search" type="submit">Search</button>
                </div>
            </div>
        </div>
    </form>

        <hr class="hr" />

        
    </div>
       <% if (typeof city !== 'undefined' && city !== null) { %>
        <div class="s-container">
            <div class="div-c">
                <h1 class="city-name"><%= city %></h1>
            </div>
            <div class="div-t">
                <h2 class="m-3 temp"><%= temp %> °C</h2>
            </div>
            <div class="div-desc">
                <h3 class="desc"><%= desc %></h3>
            </div>
            <div class="div-img">
                <img class="img" src="<%= img %>">
            </div>
        </div>
        <% } %>

       <% if (typeof error !== 'undefined' && error !== null) { %>
        <div id="unf" class="alert alert-danger mt-3">
            <%= error %>
        </div>
       <% } %>
       
    </div>
</body>
</html>